    "# fibonacci number series"
   ]
  },
  {
   "cell_type": "markdown",
   "id": "2303b4f8",
   "metadata": {},
   "source": [
    "### code: "
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 1,
   "id": "e862362d",
   "metadata": {},
   "outputs": [],
   "source": [
    "class Solution(object):\n",
    "    def fib(self, n):\n",
    "        if n==1:\n",
    "            return 1\n",
    "        if n==0:\n",
    "            return 0 \n",
    "        \n",
    "        return  self.fib(n-1)+self.fib(n-2)\n",
    "\n",
    "        "
   ]
  }
