   "source": [
    "# Recursive insertion sort"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "id": "f081e067",
   "metadata": {},
   "outputs": [],
   "source": [
    "def insertion(arr,n):\n",
    "    if n==1:\n",
    "        return \n",
    "    insertion(arr,n-1)\n",
    "    key=arr[n-1]\n",
    "    j=arr[n-2]\n",
    "    while j>0 and arr[j]>key:\n",
    "        arr[j+1]=arr[j]\n",
    "        j-=1\n",
    "    arr[j+1]=key\n",
    "    return arr\n",
    "\n",
    "arr=list(map(int,input().split()))\n",
    "n=len(arr)\n"
   ]
  }
 ],
