   "source": [
    "# Factorial of a given number using recursion "
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 5,
   "id": "1e2efd55",
   "metadata": {},
   "outputs": [
    {
     "name": "stdout",
     "output_type": "stream",
     "text": [
      "120\n"
     ]
    }
   ],
   "source": [
    "n=int(input())\n",
    "def fact(n):\n",
    "    if n==0:\n",
    "        return 1\n",
    "    return  n*fact(n-1)\n",
    "print(fact(n))"
   ]
