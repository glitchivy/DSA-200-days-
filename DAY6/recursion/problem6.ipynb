   "source": [
    "# REVERSE AN ARRAY"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "id": "98498e81",
   "metadata": {},
   "outputs": [
    {
     "name": "stdout",
     "output_type": "stream",
     "text": [
      "[3, 2, 1]\n"
     ]
    }
   ],
   "source": [
    "arr=list(map(int,input().split()))\n",
    "result=[]\n",
    "n=len(arr)\n",
    "def rev(count,arr,n):\n",
    "    if count>n:\n",
    "        return \n",
    "    result.append(arr[-count])\n",
    "    return rev(count+1,arr,n)\n",
    "\n",
    "rev(1,arr,n)    \n",
    "print(result)\n"
   ]
  },
